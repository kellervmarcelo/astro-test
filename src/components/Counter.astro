---
// Componente interativo — "ilha" com script inline
// Apenas ESTE componente terá JS no navegador. O resto da página é HTML puro!
---

<div class="flex flex-col items-center gap-6" data-counter>
  <div class="text-6xl font-extrabold text-astro min-w-[120px]">0</div>
  <div class="flex gap-3">
    <button class="bg-slate-700 text-slate-200 border-none rounded-lg px-5 py-3 text-xl cursor-pointer transition-colors duration-200 hover:bg-astro" data-action="minus">−</button>
    <button class="bg-slate-700 text-slate-200 border-none rounded-lg px-4 py-3 text-sm cursor-pointer transition-colors duration-200 hover:bg-astro" data-action="reset">Reset</button>
    <button class="bg-slate-700 text-slate-200 border-none rounded-lg px-5 py-3 text-xl cursor-pointer transition-colors duration-200 hover:bg-astro" data-action="plus">+</button>
  </div>
</div>

<script is:inline>
  document.querySelectorAll('[data-counter]').forEach((el) => {
    let count = 0;
    const display = el.querySelector('div');

    el.querySelectorAll('[data-action]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const action = btn.dataset.action;
        if (action === 'plus') count++;
        else if (action === 'minus') count--;
        else count = 0;
        display.textContent = count;
      });
    });
  });
</script>

---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { data, slug } = post;

const formattedDate = data.date.toLocaleDateString('pt-BR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const resolve = (path: string) => {
  const base = import.meta.env.BASE_URL || '/';
  const cleanBase = base.endsWith('/') ? base.slice(0, -1) : base;
  return cleanBase + path;
};
---

<article
  class="group block bg-slate-800 border border-slate-700 rounded-xl p-6 transition-all duration-200 hover:-translate-y-1 hover:border-astro hover:shadow-lg hover:shadow-astro/10"
>
  <a href={resolve(`/blog/${slug}`)} class="block">
    <time class="text-sm text-slate-500 mb-2 block">{formattedDate}</time>
    <h3 class="text-xl font-semibold text-slate-100 mb-2 group-hover:text-astro transition-colors">
      {data.title}
    </h3>
    <p class="text-slate-400 text-sm mb-4 line-clamp-2">
      {data.description}
    </p>
  </a>
  {data.tags && data.tags.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-4">
      {data.tags.map((tag) => (
        <a
          href={resolve(`/blog/tags/${tag}`)}
          class="text-xs bg-slate-700 text-slate-300 px-2 py-1 rounded-full hover:bg-slate-600 hover:text-astro transition-colors"
        >
          {tag}
        </a>
      ))}
    </div>
  )}
  <a
    href={resolve(`/blog/${slug}`)}
    class="inline-block text-astro text-sm font-medium hover:text-astro-light transition-colors group-hover:translate-x-1 transform"
  >
    Ler mais →
  </a>
</article>

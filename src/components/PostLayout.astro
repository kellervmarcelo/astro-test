---
import BaseLayout from '../layouts/BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  tags?: string[];
}

const { title, date, tags } = Astro.props;

const formattedDate = date.toLocaleDateString('pt-BR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const resolve = (path: string) => {
  const base = import.meta.env.BASE_URL || '/';
  const cleanBase = base.endsWith('/') ? base.slice(0, -1) : base;
  return cleanBase + path;
};
---

<BaseLayout>
  <article class="post-container">
    <header class="post-header">
      <a
        href={resolve('/blog')}
        class="back-link"
      >
        ← Voltar para o blog
      </a>
      <h1 class="post-title">{title}</h1>
      <div class="post-meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        {tags && tags.length > 0 && (
          <div class="post-tags">
            {tags.map((tag) => (
              <a
                href={resolve(`/blog/tags/${tag}`)}
                class="post-tag"
              >
                {tag}
              </a>
            ))}
          </div>
        )}
      </div>
    </header>

    <div class="post-content">
      <slot />
    </div>
  </article>
</BaseLayout>

<style is:global>
.post-container {
  max-width: 720px;
  margin: 0 auto;
  padding: 3rem 1.5rem;
}

.post-header {
  margin-bottom: 2.5rem;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid rgb(51 65 85 / 0.5);
}

.back-link {
  display: inline-block;
  color: rgb(148 163 184);
  font-size: 0.875rem;
  margin-bottom: 1rem;
  transition: color 0.2s;
  text-decoration: none;
}

.back-link:hover {
  color: #FF5D01;
}

.post-title {
  font-family: 'Inter', system-ui, -apple-system, sans-serif;
  font-size: 2.25rem;
  font-weight: 800;
  color: rgb(241 245 249);
  line-height: 1.2;
  margin-bottom: 0.75rem;
  letter-spacing: -0.025em;
}

.post-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 1rem;
  color: rgb(100 116 139);
  font-size: 0.875rem;
}

.post-meta time {
  font-weight: 500;
}

.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.post-tag {
  background: rgb(30 41 59);
  color: rgb(203 213 225);
  padding: 0.25rem 0.625rem;
  border-radius: 9999px;
  font-size: 0.75rem;
  font-weight: 500;
  transition: all 0.2s;
  text-decoration: none;
}

.post-tag:hover {
  background: rgb(51 65 85);
  color: #FF5D01;
}

/* Post Content - Tipografia Otimizada */
.post-content {
  font-family: 'Source Serif 4', Georgia, Cambria, 'Times New Roman', serif;
  font-size: 1.125rem;
  line-height: 1.8;
  color: rgb(203 213 225);
}

.post-content h1,
.post-content h2,
.post-content h3,
.post-content h4,
.post-content h5,
.post-content h6 {
  font-family: 'Inter', system-ui, -apple-system, sans-serif;
  color: rgb(241 245 249);
  font-weight: 700;
  line-height: 1.3;
  margin-top: 2.5rem;
  margin-bottom: 1rem;
  letter-spacing: -0.025em;
}

.post-content h1 {
  font-size: 1.875rem;
  font-weight: 800;
}

.post-content h2 {
  font-size: 1.5rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid rgb(51 65 85 / 0.3);
}

.post-content h3 {
  font-size: 1.25rem;
}

.post-content p {
  margin-bottom: 1.5rem;
}

.post-content a {
  color: #FF5D01;
  text-decoration: underline;
  text-underline-offset: 0.2em;
  transition: color 0.2s;
}

.post-content a:hover {
  color: #FF8C42;
}

.post-content strong {
  font-weight: 600;
  color: rgb(241 245 249);
}

.post-content code {
  font-family: 'Fira Code', 'Cascadia Code', 'Consolas', monospace;
  font-size: 0.875em;
  background: rgb(30 41 59);
  padding: 0.125rem 0.375rem;
  border-radius: 0.25rem;
  color: rgb(251 146 60);
}

.post-content pre {
  background: rgb(15 23 42);
  border: 1px solid rgb(51 65 85);
  border-radius: 0.5rem;
  padding: 1rem 1.25rem;
  margin: 1.5rem 0;
  overflow-x: auto;
  font-size: 0.875rem;
  line-height: 1.7;
}

.post-content pre code {
  background: transparent;
  padding: 0;
  color: inherit;
  font-size: inherit;
}

.post-content blockquote {
  border-left: 3px solid #FF5D01;
  padding-left: 1.25rem;
  margin: 1.5rem 0;
  font-style: italic;
  color: rgb(148 163 184);
}

.post-content ul,
.post-content ol {
  margin: 1.25rem 0;
  padding-left: 1.5rem;
}

.post-content li {
  margin-bottom: 0.5rem;
}

.post-content ul li {
  list-style-type: disc;
}

.post-content ol li {
  list-style-type: decimal;
}

.post-content hr {
  border: none;
  border-top: 1px solid rgb(51 65 85 / 0.5);
  margin: 2rem 0;
}

.post-content table {
  width: 100%;
  border-collapse: collapse;
  margin: 1.5rem 0;
  font-size: 1rem;
}

.post-content th {
  background: rgb(30 41 59);
  color: rgb(241 245 249);
  font-weight: 600;
  padding: 0.75rem 1rem;
  text-align: left;
  border: 1px solid rgb(51 65 85);
}

.post-content td {
  padding: 0.75rem 1rem;
  border: 1px solid rgb(51 65 85);
}

.post-content tr:nth-child(even) {
  background: rgb(30 41 59 / 0.3);
}

.post-content img {
  max-width: 100%;
  height: auto;
  border-radius: 0.5rem;
  margin: 1.5rem 0;
}

/* Responsividade */
@media (max-width: 768px) {
  .post-container {
    padding: 2rem 1rem;
  }

  .post-title {
    font-size: 1.75rem;
  }

  .post-content {
    font-size: 1rem;
    line-height: 1.75;
  }

  .post-content h1 {
    font-size: 1.5rem;
  }

  .post-content h2 {
    font-size: 1.25rem;
  }

  .post-content pre {
    padding: 0.75rem;
    font-size: 0.8rem;
  }
}
</style>

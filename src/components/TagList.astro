---
interface TagInfo {
  tag: string;
  count: number;
}

interface Props {
  tags: string[] | TagInfo[];
  currentTag?: string;
  baseUrl?: string;
  showCount?: boolean;
}

const { tags, currentTag, baseUrl = '/blog/tags', showCount = true } = Astro.props;

const resolve = (path: string) => {
  const base = import.meta.env.BASE_URL || '/';
  const cleanBase = base.endsWith('/') ? base.slice(0, -1) : base;
  return cleanBase + path;
};

// Verificar se é array de TagInfo ou string[]
const isTagInfo = (t: string | TagInfo): t is TagInfo => typeof t === 'object' && 'tag' in t;
---

<div class="flex flex-wrap gap-2">
  <!-- Link para ver todas as tags -->
  <a
    href={resolve(baseUrl)}
    class:list={[
      'tag-link text-sm px-3 py-1.5 rounded-full transition-colors font-medium',
      !currentTag
        ? 'bg-astro text-white'
        : 'bg-slate-800 text-slate-300 hover:bg-slate-700 hover:text-astro',
    ]}
  >
    Todas
  </a>

  {tags.map((t) => {
    const tag = isTagInfo(t) ? t.tag : t;
    const count = isTagInfo(t) ? t.count : undefined;
    return (
      <a
        href={resolve(`${baseUrl}/${tag}`)}
        class:list={[
          'tag-link text-sm px-3 py-1.5 rounded-full transition-colors font-medium inline-flex items-center gap-1.5',
          currentTag === tag
            ? 'bg-astro text-white'
            : 'bg-slate-800 text-slate-300 hover:bg-slate-700 hover:text-astro',
        ]}
      >
        {tag}
        {showCount && count !== undefined && (
          <span class:list={[
            'text-xs px-1.5 py-0.5 rounded-full',
            currentTag === tag
              ? 'bg-white/20 text-white'
              : 'bg-slate-700 text-slate-400',
          ]}>
            {count}
          </span>
        )}
      </a>
    );
  })}
</div>

<style>
.tag-link {
  text-decoration: none;
}
</style>

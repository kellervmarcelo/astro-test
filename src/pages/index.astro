---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const recentPosts = posts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const resolve = (path: string) => {
  const base = import.meta.env.BASE_URL || '/';
  const cleanBase = base.endsWith('/') ? base.slice(0, -1) : base;
  return cleanBase + path;
};
---

<BaseLayout>
  <!-- Hero Section -->
  <header class="text-center px-4 pt-20 pb-12">
    <div class="hero-content max-w-2xl mx-auto">
      <div class="mb-6">
        <div class="w-32 h-32 mx-auto rounded-full bg-gradient-to-br from-astro to-astro-light p-1">
          <div class="w-full h-full rounded-full bg-slate-800 flex items-center justify-center text-5xl">
            👨‍💻
          </div>
        </div>
      </div>
      <h1 class="hero-title text-5xl md:text-6xl font-extrabold bg-gradient-to-br from-astro to-astro-light bg-clip-text text-transparent mb-3">
        Kellerv Marcelo
      </h1>
      <p class="hero-subtitle text-slate-400 text-xl md:text-2xl mb-4">
        Desenvolvedor & Escritor
      </p>
      <p class="hero-description text-slate-500 text-lg max-w-xl mx-auto">
        Compartilho minha jornada aprendendo e construindo com Astro, Vue e tecnologias web modernas.
      </p>
      <div class="mt-8 flex gap-4 justify-center">
        <a
          href={resolve('/blog')}
          class="bg-astro hover:bg-astro-light text-white px-6 py-3 rounded-lg font-medium transition-colors inline-block"
        >
          Ver todos os posts
        </a>
        <a
          href="#sobre"
          class="bg-slate-800 hover:bg-slate-700 text-slate-200 px-6 py-3 rounded-lg font-medium transition-colors border border-slate-700 inline-block"
        >
          Sobre mim
        </a>
      </div>
      <div class="scroll-arrow mt-12 text-slate-500 text-2xl">↓</div>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-4 py-8">
    <!-- Posts Recentes -->
    <section class="mb-16 anim-section">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-3xl font-bold text-slate-100">
          📝 Posts Recentes
        </h2>
        <a href={resolve('/blog')} class="text-astro hover:text-astro-light transition-colors font-medium">
          Ver todos →
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {recentPosts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>
    </section>

    <!-- Sobre -->
    <section id="sobre" class="mb-16 anim-section">
      <div class="bg-slate-800 border border-slate-700 rounded-xl p-8">
        <h2 class="text-2xl font-bold text-slate-100 mb-4">
          👋 Sobre Mim
        </h2>
        <div class="text-slate-400 space-y-3">
          <p>
            Olá! Sou o <strong class="text-slate-200">Kellerv Marcelo</strong>, um apaixonado por desenvolvimento web e tecnologia.
          </p>
          <p>
            Criei este blog como um espaço para compartilhar aprendizados, tutoriais e insights sobre 
            <span class="text-astro">Astro</span>, 
            <span class="text-astro">Vue.js</span>, e o ecossistema web moderno.
          </p>
          <p>
            Acredito que a melhor forma de aprender é ensinando, e este blog é exatamente isso — minha jornada de aprendizado compartilhada com você.
          </p>
        </div>
        <div class="mt-6 flex gap-4">
          <a
            href="https://github.com/kellervmarcelo"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-slate-700 hover:bg-slate-600 text-slate-200 px-4 py-2 rounded-lg transition-colors text-sm"
          >
            GitHub
          </a>
          <a
            href="mailto:seu-email@exemplo.com"
            class="bg-slate-700 hover:bg-slate-600 text-slate-200 px-4 py-2 rounded-lg transition-colors text-sm"
          >
            Email
          </a>
        </div>
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="mb-16 anim-section">
      <div class="text-center mb-8">
        <h2 class="text-2xl font-bold text-slate-100 mb-2">
          🚀 Tecnologias que Uso
        </h2>
        <p class="text-slate-500">No meu dia a dia e neste blog</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-slate-800 border border-slate-700 rounded-xl p-4 text-center hover:border-astro transition-colors">
          <div class="text-3xl mb-2">⚡</div>
          <div class="text-slate-200 font-medium">Astro</div>
        </div>
        <div class="bg-slate-800 border border-slate-700 rounded-xl p-4 text-center hover:border-astro transition-colors">
          <div class="text-3xl mb-2">💚</div>
          <div class="text-slate-200 font-medium">Vue.js</div>
        </div>
        <div class="bg-slate-800 border border-slate-700 rounded-xl p-4 text-center hover:border-astro transition-colors">
          <div class="text-3xl mb-2">🎨</div>
          <div class="text-slate-200 font-medium">Tailwind</div>
        </div>
        <div class="bg-slate-800 border border-slate-700 rounded-xl p-4 text-center hover:border-astro transition-colors">
          <div class="text-3xl mb-2">📝</div>
          <div class="text-slate-200 font-medium">Markdown</div>
        </div>
      </div>
    </section>

    <!-- CTA Final -->
    <section class="text-center p-8 bg-gradient-to-br from-astro/10 to-astro-light/10 border border-astro/20 rounded-xl mb-8 anim-section">
      <h2 class="text-2xl font-bold text-slate-100 mb-3">
        Pronto para aprender?
      </h2>
      <p class="text-slate-400 mb-6 max-w-lg mx-auto">
        Navegue pelos posts, explore as tags e venha aprender comigo sobre desenvolvimento web moderno.
      </p>
      <a
        href={resolve('/blog')}
        class="bg-astro hover:bg-astro-light text-white px-8 py-3 rounded-lg font-medium transition-colors inline-block"
      >
        Explorar Blog Completo
      </a>
    </section>
  </main>

  <footer class="site-footer text-center px-4 py-8 text-slate-500 text-sm border-t border-slate-800">
    <p>Criado com ❤️ usando Astro — Zero JavaScript por padrão</p>
    <p class="mt-2 text-xs text-slate-600">
      © 2026 Kellerv Marcelo. Todos os direitos reservados.
    </p>
  </footer>
</BaseLayout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  if (!prefersReducedMotion.matches) {
    // Hero animations
    gsap.from('.hero-content', { y: 40, opacity: 0, duration: 1, ease: 'power3.out', delay: 0.2 });
    gsap.to('.scroll-arrow', { y: 10, repeat: -1, yoyo: true, duration: 0.8, ease: 'sine.inOut' });

    // Section reveal on scroll
    const sections = gsap.utils.toArray<HTMLElement>('.anim-section');
    sections.forEach((section) => {
      gsap.from(section as Element, {
        y: 50, opacity: 0, duration: 0.8, ease: 'power2.out',
        scrollTrigger: { trigger: section, start: 'top 85%', once: true },
      });
    });

    // Footer
    gsap.from('.site-footer', {
      opacity: 0, duration: 0.6,
      scrollTrigger: { trigger: '.site-footer', start: 'top 95%', once: true },
    });
  }
</script>

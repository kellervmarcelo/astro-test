---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import TagList from '../../components/TagList.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const allTags = [...new Set(posts.flatMap((post) => post.data.tags ?? []))].sort();

// Filtrar por tag se existir na query
const url = new URL(Astro.request.url);
const tagFilter = url.searchParams.get('tag');
const filteredPosts = tagFilter
  ? posts.filter((post) => post.data.tags?.includes(tagFilter))
  : posts;

const resolve = (path: string) => {
  const base = import.meta.env.BASE_URL || '/';
  const cleanBase = base.endsWith('/') ? base.slice(0, -1) : base;
  return cleanBase + path;
};
---

<BaseLayout>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <!-- Header -->
    <header class="mb-12">
      <a
        href={resolve('/')}
        class="inline-block text-slate-400 hover:text-astro mb-4 transition-colors text-sm"
      >
        ← Voltar para a home
      </a>
      <h1 class="text-4xl md:text-5xl font-extrabold text-slate-100 mb-3">
        📝 Blog
      </h1>
      <p class="text-slate-400 text-lg">
        Minhas anotações e aprendizados sobre desenvolvimento web
      </p>
    </header>

    <!-- Tags -->
    {allTags.length > 0 && (
      <section class="mb-8">
        <h2 class="text-sm text-slate-500 mb-3 uppercase tracking-wide">Filtrar por tag</h2>
        <TagList tags={allTags} currentTag={tagFilter ?? undefined} />
      </section>
    )}

    <!-- Posts -->
    <section>
      {tagFilter && (
        <div class="mb-6">
          <p class="text-slate-400">
            Mostrando posts com tag <span class="text-astro font-medium">"{tagFilter}"</span>
            <a href={resolve('/blog')} class="text-slate-500 hover:text-slate-300 ml-2 text-sm">
              Limpar filtro ×
            </a>
          </p>
        </div>
      )}

      {filteredPosts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {filteredPosts.map((post) => (
            <BlogCard post={post} />
          ))}
        </div>
      ) : (
        <div class="text-center py-16 bg-slate-800 rounded-xl">
          <p class="text-slate-400 text-lg">
            {tagFilter
              ? `Nenhum post encontrado com a tag "${tagFilter}".`
              : 'Nenhum post encontrado.'}
          </p>
        </div>
      )}
    </section>

    <!-- Stats -->
    <footer class="mt-12 pt-8 border-t border-slate-800 text-center text-slate-500 text-sm">
      <p>
        {filteredPosts.length} {filteredPosts.length === 1 ? 'post' : 'posts'} publicado{filteredPosts.length !== 1 ? 's' : ''}
        {tagFilter && ` com a tag "${tagFilter}"`}
      </p>
    </footer>
  </div>
</BaseLayout>
